TTS_HOST=127.0.0.1
TTS_PORT=8200

# Model: switch to mlx-community/Qwen3-TTS-12Hz-1.7B-CustomVoice-8bit if you migrate to MLX
TTS_MODEL_ID=Qwen/Qwen3-TTS-12Hz-1.7B-CustomVoice

# Device: auto picks mps on Apple Silicon, cuda on NVIDIA, else cpu
TTS_DEVICE=auto
TTS_DTYPE=float16

# Load weights at startup (slow, ~3.8GB) vs lazy on first request
TTS_EAGER_LOAD=false
