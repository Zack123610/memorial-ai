TTS_HOST=127.0.0.1
TTS_PORT=8200

# Base model supports zero-shot voice cloning from reference audio (required for Memorial AI)
# CustomVoice variant (Qwen/Qwen3-TTS-12Hz-1.7B-CustomVoice) only supports predefined speakers
TTS_MODEL_ID=Qwen/Qwen3-TTS-12Hz-1.7B-Base

# Device: auto picks mps on Apple Silicon, cuda on NVIDIA, else cpu
TTS_DEVICE=auto
TTS_DTYPE=float16

# Load weights at startup (slow, ~3.8GB) vs lazy on first request
TTS_EAGER_LOAD=false
