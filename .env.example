# Server
PORT=3001
NODE_ENV=development

# TTS service (FastAPI / Qwen3-TTS)
TTS_SERVICE_URL=http://localhost:8200

# Video service (FastAPI / DashScope Wan2.7 i2v)
# This service has its own .env (DashScope key, S3 config) — see video-service/.env.example
VIDEO_SERVICE_URL=http://localhost:8300

# Redis (BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6379

# Storage
STORAGE_DIR=./storage
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=50

# Client
VITE_API_BASE=http://localhost:3001
VITE_SOCKET_URL=http://localhost:3001
