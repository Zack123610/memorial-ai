# Server
PORT=3001
NODE_ENV=development

# ComfyUI
COMFYUI_URL=http://localhost:8188

# TTS service (FastAPI / Qwen3-TTS)
TTS_SERVICE_URL=http://localhost:8200

# Redis (BullMQ)
