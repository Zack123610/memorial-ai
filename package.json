{
  "name": "memorial-ai",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "AI-powered farewell video generation",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:server dev:client",
    "dev:client": "npm run dev --workspace client",
    "dev:server": "npm run dev --workspace server",
    "build": "npm-run-all build:server build:client",
    "build:client": "npm run build --workspace client",
    "build:server": "npm run build --workspace server",
    "lint": "eslint \"{client,server}/src/**/*.{ts,tsx}\"",
    "format": "prettier --write \"{client,server}/src/**/*.{ts,tsx,json,css,md}\"",
    "format:check": "prettier --check \"{client,server}/src/**/*.{ts,tsx,json,css,md}\"",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^15.15.0",
    "husky": "^9.1.0",
    "lint-staged": "^15.2.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.3.0",
    "typescript": "^5.5.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=20"
  }
}
