VIDEO_HOST=127.0.0.1
VIDEO_PORT=8300

# Aliyun DashScope — image+audio → talking-head video (Wan2.7 i2v)
DASHSCOPE_API_KEY=
VIDEO_DASHSCOPE_BASE=https://dashscope.aliyuncs.com
VIDEO_DASHSCOPE_MODEL=wan2.7-i2v-2026-04-25

# S3 — uploaded inputs are hosted here (DashScope needs public URLs) and the
# generated video is archived back here under a stable URL.
S3_BUCKET=img-web-req
S3_REGION=ap-southeast-1
S3_INPUT_PREFIX=memorial/inputs
S3_OUTPUT_PREFIX=memorial/outputs
# Optional: CDN / custom-domain base for public URLs. Defaults to the
# virtual-hosted bucket endpoint built from S3_BUCKET + S3_REGION.
# S3_PUBLIC_BASE=https://img-web-req.s3.ap-southeast-1.amazonaws.com
# Leave blank to use the default AWS credential chain (env / shared config / role).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Generation defaults (overridable per-request)
VIDEO_DEFAULT_RESOLUTION=720P
VIDEO_DEFAULT_DURATION=5
VIDEO_DEFAULT_PROMPT_EXTEND=true
VIDEO_DEFAULT_WATERMARK=false

# How long to wait for the async task to finish (seconds), and poll interval
VIDEO_TASK_TIMEOUT=600
VIDEO_POLL_INTERVAL=30
